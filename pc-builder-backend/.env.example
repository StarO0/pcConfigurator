APP_NAME=PC Configurator Unified API
APP_VERSION=6.0.0
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

SECRET_KEY=replace-with-at-least-32-random-characters
TOKEN_PEPPER=replace-with-another-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

DATABASE_URL=postgresql+asyncpg://pcbuilder:pcbuilder-local-change-in-production@localhost:5432/pcbuilder
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

CORS_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
AUTO_CREATE_TABLES=false
SEED_DEMO_DATA=false
STARTER_SNAPSHOT_ENABLED=true
STARTER_SNAPSHOT_PATH=data/starter-snapshot-pl-2026-07-15.json
PRUNE_INCOMPLETE_CATALOG=true
ADMIN_BOOTSTRAP_EMAIL=admin@pcbuilder.app
ADMIN_BOOTSTRAP_PASSWORD=Local-admin-123

PUBLIC_COLLECTORS_ENABLED=false
HARVESTER_SCHEDULER_ENABLED=false
COLLECTOR_USER_AGENT=PCConfiguratorBot/6.0 (+mailto:replace-with-your-email@example.com)
COLLECTOR_MIN_DELAY_SECONDS=1.5
COLLECTOR_MAX_PAGES_PER_RUN=100
COLLECTOR_REQUIRE_ROBOTS=true
OPEN_ICECAT_ENABLED=true
OPEN_ICECAT_SHOPNAME=openIcecat-live
OPEN_ICECAT_LANGUAGE=en

CENEO_ENABLED=false
CENEO_API_KEY=
CENEO_PARTNER_ID=
CENEO_SERVICE=partner

AI_PROVIDER=rules
AI_FALLBACK_PROVIDER=rules
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

NBP_RATES_URL=https://api.nbp.pl/api/exchangerates/tables/A?format=json
OFFER_STALE_HOURS=12
DEFAULT_CURRENCY=PLN
FRONTEND_URL=http://localhost:3000
SMTP_HOST=
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_JSON=true
ENABLE_METRICS=true
